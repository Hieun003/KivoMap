rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUser(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function validAuthIdentity() {
      return (!request.resource.data.keys().hasAny(['phoneNumber']) ||
              request.resource.data.phoneNumber == request.auth.token.phone_number) &&
             (!request.resource.data.keys().hasAny(['email']) ||
              request.resource.data.email == request.auth.token.email);
    }

    match /users/{userId} {
      allow read, delete: if ownsUser(userId);

      allow create: if ownsUser(userId) &&
        request.resource.data.keys().hasOnly([
          'name',
          'email',
          'phoneNumber',
          'avatarKey',
          'isNewbieDiscover',
          'createdAt',
          'updatedAt'
        ]) &&
        validAuthIdentity();

      allow update: if ownsUser(userId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name',
          'email',
          'phoneNumber',
          'avatarKey',
          'isNewbieDiscover',
          'lastLoginAt',
          'updatedAt'
        ]) &&
        validAuthIdentity();

      match /{document=**} {
        allow read, write: if ownsUser(userId);
      }
    }

    match /knowledge_clusters/{document=**} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /knowledge_links/{document=**} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /context_details/{document=**} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /passageway_combos/{document=**} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /system/{document=**} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
